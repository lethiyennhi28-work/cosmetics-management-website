@model Nhom5_Mypham.Models.HOADON
@{ Layout = null; }

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>In hóa đơn #@Model.MaHD</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <style>
        body {
            font-family: Arial, sans-serif;
            padding: 20px;
            line-height: 1.5;
            color: #333;
            background-color: #f5f5f5;
            margin: 0;
        }

        .invoice-box {
            background-color: #fff;
            padding: 30px;
            width: 800px;
            max-width: 100%;
            margin: 0 auto;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
            position: relative;
            z-index: 1;
            overflow: hidden;
            min-height: 1050px; 
            box-sizing: border-box; 
        }

        .watermark {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 650px; 
            opacity: 0.12;
            z-index: -1;
            pointer-events: none;
        }

        .header-container {
            display: flex;
            align-items: flex-start;
            border-bottom: 2px solid #2d9446;
            padding-bottom: 20px;
            margin-bottom: 30px;
            position: relative;
            z-index: 10;
        }

        .logo-box {
            margin-right: 25px;
        }

            .logo-box img {
                width: 140px;
            }

        .company-info {
            flex: 1;
            text-align: left;
        }

        .company-info h1 {
            color: #2d9446;
            margin: 0;
            font-size: 22px;
            text-transform: uppercase;
            font-weight: bold;
        }

        .company-info p {
            margin: 2px 0;
            font-size: 13px;
            color: #444;
        }

        .invoice-title {
            text-align: center;
            text-transform: uppercase;
            margin: 30px 0 20px 0;
            font-size: 24px;
            font-weight: bold;
            position: relative;
            z-index: 10;
        }

        .info-section {
            display: flex;
            justify-content: space-between;
            position: relative;
            z-index: 10;
            margin-bottom: 20px;
            font-size: 14px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
            position: relative;
            z-index: 10;
            background-color: transparent;
        }

        th {
            background-color: rgba(248, 249, 250, 0.8);
            color: #333;
            font-weight: bold;
            border-bottom: 2px solid #ddd;
            padding: 10px;
            text-align: left;
        }

        td {
            padding: 10px;
            border-bottom: 1px solid #eee;
            text-align: left;
            font-size: 14px;
        }

        .footer {
            margin-top: 40px;
            text-align: right;
            position: relative;
            z-index: 10;
        }

        .total-amount {
            font-size: 20px;
            color: #d9534f;
            font-weight: bold;
        }

        .signature-section {
            margin-top: 50px;
            display: flex;
            justify-content: space-between;
            text-align: center;
            position: relative;
            z-index: 10;
        }

        .signature-box {
            width: 40%;
        }

        .btn-print-group {
            text-align: center;
            margin-bottom: 20px;
        }

        .btn-print {
            background-color: #2d9446;
            color: white;
            border: none;
            padding: 10px 25px;
            border-radius: 30px;
            cursor: pointer;
            font-weight: bold;
        }

        @@media print {
            @@page {
                size: A4;
                margin: 0; 
            }

            .btn-print-group {
                display: none;
            }

            body {
                padding: 0;
                background-color: #fff;
            }

            .invoice-box {
                border: none;
                box-shadow: none;
                width: 100%; 
                padding: 1cm;
            }
        }
    </style>
</head>
<body>

    <div class="btn-print-group">
        <button class="btn-print" onclick="window.print()">
            <i class="fas fa-print"></i> Bấm để In / Lưu PDF
        </button>
    </div>

    <div class="invoice-box">
        <img src="~/Images/logo.png" class="watermark" alt="Watermark" />

        <div class="header-container">
            <div class="company-info">
                <h1>Mỹ phẩm Cocoon</h1>
                <p><b>Văn phòng:</b> 7/50A Đường 182, Tăng Nhơn Phú A, TP. Thủ Đức, TP. HCM</p>
                <p><b>Hotline:</b> 0972 383 373</p>
                <p><b>Website:</b> www.cocoonvietnam.com</p>
            </div>
        </div>

        <h2 class="invoice-title">Hóa đơn bán hàng</h2>

        <div class="info-section">
            <div>
                <p><b>Mã đơn:</b> #@Model.MaHD</p>
                <p><b>Ngày lập:</b> @(Model.NgayLap.HasValue ? Model.NgayLap.Value.ToString("dd/MM/yyyy HH:mm") : "N/A")</p>
            </div>
            <div style="text-align: right;">
                <p><b>Khách hàng:</b> @(Model.KHACHHANG != null ? Model.KHACHHANG.HoTen : "Khách vãng lai")</p>
                <p><b>SĐT:</b> @(Model.KHACHHANG != null ? Model.KHACHHANG.SDT : "N/A")</p>
            </div>
        </div>

        <table>
            <thead>
                <tr>
                    <th style="width: 50px; text-align: center;">STT</th>
                    <th>Tên sản phẩm</th>
                    <th style="text-align: center;">SL</th>
                    <th style="text-align: right;">Đơn giá</th>
                    <th style="text-align: right;">Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @{ int stt = 1; }
                @foreach (var ct in Model.CHITIETHOADONs)
                {
                    <tr>
                        <td style="text-align: center;">@(stt++)</td>
                        <td><b>@ct.SANPHAM.TenSP</b></td>
                        <td style="text-align: center;">@ct.SoLuong</td>
                        <td style="text-align: right;">@String.Format("{0:N0}", ct.DonGia) ₫</td>
                        <td style="text-align: right;">@String.Format("{0:N0}", ct.ThanhTien) ₫</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="footer">
            <div class="total-amount">
                TỔNG THANH TOÁN: @String.Format("{0:N0}", Model.TongTien) ₫
            </div>
            <p style="font-style: italic; color: #666; margin-top: 10px;">Cảm ơn quý khách đã tin dùng sản phẩm Cocoon!</p>

            <div class="signature-section">
                <div class="signature-box">
                    <b>Người mua hàng</b><br>
                    <small>(Ký, ghi rõ họ tên)</small>
                </div>
                <div class="signature-box">
                    <b>Người bán hàng</b><br>
                    <small>(Ký, ghi rõ họ tên)</small>
                    <div style="margin-top: 60px;">
                        <b>@(Model.NHANVIEN != null ? Model.NHANVIEN.HoTen : "Nhân viên bán hàng")</b>
                    </div>
                </div>
            </div>

            <div style="margin-top: 80px; font-size: 11px; color: #bbb; text-align: center;">
                * Hóa đơn này có giá trị xác nhận giao dịch thành công. Hệ thống quản lý Cocoon © 2025
            </div>
        </div>
    </div>
</body>
</html>