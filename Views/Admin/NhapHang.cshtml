@model Nhom5_Mypham.Models.SANPHAM

@{
    ViewBag.Title = "Nhập kho sản phẩm";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow border-0">
                <div class="card-header text-white" style="background: #2e7d32">
                    <h4 class="mb-0 fw-bold text-uppercase"><i class="fas fa-boxes me-2"></i> NHẬP KHO HÀNG HÓA</h4>
                </div>

                <div class="card-body p-4">
                    <div class="alert alert-success d-flex align-items-center">
                        <i class="fas fa-info-circle fa-2x me-3"></i>
                        <div>
                            Bạn đang nhập hàng cho sản phẩm:<br />
                            <strong class="fs-5">@Model.TenSP</strong>
                            <div class="text-muted small">Mã SP: @Model.MaSP</div>
                        </div>
                    </div>

                    @using (Html.BeginForm("NhapHang", "Admin", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()

                        <input type="hidden" name="id" value="@Model.MaSP" />

                        <div class="row mb-4">
                            <div class="col-md-4 text-center">
                                <img src="@Url.Content("~/Images/" + (Model.HinhAnh ?? "no-image.jpg"))"
                                     class="img-thumbnail shadow-sm"
                                     style="height: 180px; object-fit: cover; border-radius: 10px;" />
                                <p class="mt-2 fw-bold text-muted">Hiện có: <span class="text-danger">@Model.SoLuong</span> sản phẩm</p>
                            </div>

                            <div class="col-md-8">
                                <div class="mb-4">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-plus-circle text-success"></i> Số lượng nhập thêm:
                                    </label>
                                    <input type="number" name="soLuongNhap" class="form-control form-control-lg border-success"
                                           required min="1" placeholder="Ví dụ: 50" autofocus />
                                    <small class="text-muted">Nhập số lượng thực tế về kho.</small>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-money-bill-wave text-warning"></i> Giá nhập vào (VNĐ/cái):
                                    </label>
                                    <input type="number" name="giaNhap" class="form-control border-warning"
                                           required min="0" placeholder="Ví dụ: 80000" />
                                    <small class="text-muted fst-italic">
                                        * Hệ thống sẽ tự tính lại giá vốn trung bình.
                                    </small>
                                </div>
                            </div>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between align-items-center">
                            <a href="@Url.Action("Index", "Admin")" class="text-decoration-none text-secondary">
                                <i class="fas fa-arrow-left"></i> Quay lại danh sách
                            </a>

                            <button type="submit" class="btn btn-success btn-lg px-5 fw-bold shadow">
                                <i class="fas fa-save me-2"></i> XÁC NHẬN NHẬP KHO
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>