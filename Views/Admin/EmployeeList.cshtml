@model IEnumerable<Nhom5_Mypham.Models.NHANVIEN>
@{
    ViewBag.Title = "Danh sách nhân sự";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";

    string myRole = Session["ChucVu"] as string;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="fw-bold text-success text-uppercase">
            <i class="fas fa-users-cog me-2"></i> Danh sách nhân sự
        </h3>

        @if (myRole == "Giám đốc")
        {
            <button type="button" class="btn btn-success shadow-sm" data-bs-toggle="modal" data-bs-target="#modalThemNhanVien">
                <i class="fas fa-plus me-1"></i> Thêm nhân viên
            </button>
        }
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle table-bordered mb-0">
                <thead class="table-dark text-center">
                    <tr>
                        <th class="py-3">Mã NV</th>
                        <th class="py-3">Họ Tên</th>
                        <th class="py-3">Chức Vụ</th>
                        <th class="py-3">Tài khoản</th>
                        <th class="py-3">Lương Cơ Bản</th>
                        <th class="py-3" style="width: 200px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center fw-bold text-muted">@item.MaNV</td>

                            <td class="fw-bold text-dark">@item.HoTen</td>

                            <td class="text-center">
                                @if (item.ChucVu == "Giám đốc")
                                {<span class="badge bg-danger rounded-pill px-3">Giám đốc</span> }
                                else if (item.ChucVu == "Kế toán")
                                { <span class="badge bg-warning text-dark rounded-pill px-3">Kế toán</span> }
                                else if (item.ChucVu == "Trưởng phòng")
                                { <span class="badge bg-success rounded-pill px-3">Trưởng phòng</span> }
                                else if (item.ChucVu == "Phó phòng")
                                { <span class="badge bg-primary rounded-pill px-3">Phó phòng</span> }
                                else
                                { <span class="badge bg-secondary text-white rounded-pill px-3">@item.ChucVu</span>}
                            </td>

                            <td class="text-center">@item.Username</td>

                            <td class="text-end fw-bold">
                                @if (item.ChucVu == "Giám đốc")
                                {
                                    <span class="text-muted fst-italic small"><i class="fas fa-lock me-1"></i>Bảo mật</span>
                                }
                                else
                                {
                                    <span class="text-success">@string.Format("{0:N0}", item.Luong) ₫</span>
                                }
                            </td>

                            <td class="text-center">
                                @if (myRole == "Giám đốc")
                                {
                                    <a href="@Url.Action("EditRole", "Admin", new { id = item.MaNV })"
                                       class="btn btn-sm btn-outline-primary" title="Sửa quyền">
                                        <i class="fas fa-user-edit"></i>
                                    </a>

                                    if (item.TrangThai == true || item.TrangThai == null)
                                    {
                                        <a href="@Url.Action("LockAccount", "Admin", new { id = item.MaNV })"
                                           class="btn btn-sm btn-outline-danger ms-1"
                                           onclick="return confirm('CẢNH BÁO: Bạn có chắc chắn muốn KHÓA tài khoản @item.Username không?')"
                                           title="Khóa tài khoản">
                                            <i class="fas fa-lock"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <a href="@Url.Action("LockAccount", "Admin", new { id = item.MaNV })"
                                           class="btn btn-sm btn-success ms-1"
                                           onclick="return confirm('Bạn muốn MỞ KHÓA lại cho tài khoản @item.Username?')"
                                           title="Mở khóa tài khoản">
                                            <i class="fas fa-unlock-alt"></i>
                                        </a>
                                    }
                                }
                                else
                                {
                                    <span class="badge bg-light text-secondary border p-2">
                                        <i class="fas fa-eye me-1"></i> Chỉ xem
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (myRole == "Giám đốc")
{
    <div class="modal fade" id="modalThemNhanVien" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title fw-bold">Thêm nhân viên mới</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form action="@Url.Action("CreateEmployee", "Admin")" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Mã Nhân Viên</label>
                            <input type="text" name="MaNV" class="form-control" required placeholder="VD: NV099">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Họ Tên</label>
                            <input type="text" name="HoTen" class="form-control" required>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Giới tính</label>
                                <select name="GioiTinh" class="form-select">
                                    <option value="Nam">Nam</option>
                                    <option value="Nữ">Nữ</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Chức vụ</label>
                                <select name="ChucVu" class="form-select">
                                    <option value="Nhân viên">Nhân viên</option>
                                    <option value="Kế toán">Kế toán</option>
                                    <option value="Trưởng phòng">Trưởng phòng</option>
                                    <option value="Phó phòng">Phó phòng</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Lương cơ bản</label>
                            <input type="number" name="Luong" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Tên đăng nhập</label>
                            <input type="text" name="Username" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Mật khẩu</label>
                            <input type="password" name="Password" class="form-control" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-success">Lưu nhân viên</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}