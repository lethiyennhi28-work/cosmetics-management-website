@model IEnumerable<Nhom5_Mypham.Models.SANPHAM>
@{
    ViewBag.Title = "Trang chủ";
}

@functions {
    public string GetImage(string tenSP)
    {
        if (string.IsNullOrEmpty(tenSP)) return "poster.jpg";
        string s = tenSP.ToLower();
        if (s.Contains("bí đao")) return "nuoc_bi_dao.jpg";
        if (s.Contains("mặt nạ") && s.Contains("nghệ")) return "mat_na_nghe.jpg";
        if (s.Contains("tinh chất") && s.Contains("nghệ")) return "tinh_chat_nghe.jpg";
        if (s.Contains("tẩy trang") && s.Contains("hoa hồng")) return "dau_tay_trang.jpg";
        if (s.Contains("thạch") || s.Contains("hoa hồng")) return "thach_hoa_hong.jpg";
        if (s.Contains("sáp") && s.Contains("sen")) return "sap_duong_am.jpg";
        if (s.Contains("sen")) return "nuoc_sen.jpg";
        if (s.Contains("cà phê") || s.Contains("cafe")) return "cafe_daklak.jpg";
        return "poster.jpg";
    }
}

<section class="py-5" style="background-color: var(--cocoon-bg);">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-5">
                <h1 class="display-4 fw-bold mb-3" style="color: var(--cocoon-brown);">
                    Mỹ phẩm thuần chay <br>
                    <span style="color: var(--cocoon-green);">cho nét đẹp thuần Việt</span>
                </h1>
                <p class="lead mb-4 text-muted">100% vegan, không thử nghiệm trên động vật, an toàn cho làn da và mái tóc người Việt.</p>
                <a href="@Url.Action("Index","Product")" class="btn btn-cocoon me-2">Khám phá sản phẩm <i class="fas fa-arrow-right"></i></a>
                <a href="@Url.Action("About", "Home")" class="btn btn-outline-success rounded-pill fw-bold px-4">Tìm hiểu thêm</a>
                <div class="mt-4 small fw-bold text-muted">
                    <span class="me-3"><i class="fas fa-check-circle text-success"></i> 100% Vegan</span>
                    <span><i class="fas fa-paw text-success"></i> Cruelty-free</span>
                </div>
            </div>
            <div class="col-lg-7">
                <img src="@Url.Content("~/Images/poster.jpg")" class="img-fluid rounded-4 shadow" style="width: 100%; height: 450px; object-fit: cover;">
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container text-center">
        <h3 class="fw-bold mb-5" style="color: var(--cocoon-brown);">Danh mục sản phẩm</h3>
        <div class="row justify-content-center">
            <div class="col-6 col-md-2">
                <a href="@Url.Action("Category", "Product", new { id = "LI003" })" class="text-decoration-none text-dark">
                    <div class="bg-white p-3 rounded-circle shadow-sm mx-auto mb-3" style="width:80px;height:80px; display:flex; align-items:center; justify-content:center;">
                        <i class="fas fa-pump-soap fa-2x text-warning"></i>
                    </div>
                    <h6>Dưỡng da</h6>
                </a>
            </div>
            <div class="col-6 col-md-2">
                <a href="#" class="text-decoration-none text-dark">
                    <div class="bg-white p-3 rounded-circle shadow-sm mx-auto mb-3" style="width:80px;height:80px; display:flex; align-items:center; justify-content:center;">
                        <i class="fas fa-spa fa-2x text-warning"></i>
                    </div>
                    <h6>Chăm sóc tóc</h6>
                </a>
            </div>
            <div class="col-6 col-md-2">
                <a href="#" class="text-decoration-none text-dark">
                    <div class="bg-white p-3 rounded-circle shadow-sm mx-auto mb-3" style="width:80px;height:80px; display:flex; align-items:center; justify-content:center;">
                        <i class="fas fa-shower fa-2x text-warning"></i>
                    </div>
                    <h6>Tắm & Body</h6>
                </a>
            </div>
            <div class="col-6 col-md-2">
                <a href="#" class="text-decoration-none text-dark">
                    <div class="bg-white p-3 rounded-circle shadow-sm mx-auto mb-3" style="width:80px;height:80px; display:flex; align-items:center; justify-content:center;">
                        <i class="fas fa-kiss-wink-heart fa-2x text-warning"></i>
                    </div>
                    <h6>Dưỡng môi</h6>
                </a>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-white">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold" style="color: var(--cocoon-brown);"><i class="fas fa-fire text-danger"></i> Bán chạy nhất</h3>
            <a href="@Url.Action("Index", "Product")" class="text-decoration-none fw-bold text-success">Xem tất cả <i class="fas fa-arrow-right"></i></a>
        </div>

        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-3 col-6">
                    <div class="card h-100 card-product position-relative border-0 shadow-sm">
                        <span class="badge-sale">-15%</span>

                        <a href="@Url.Action("Detail", "Product", new { id = item.MaSP })">
                            <img src="@Url.Content("~/Images/" + GetImage(item.TenSP))"
                                 class="card-img-top p-3 img-product-fly"
                                 alt="@item.TenSP"
                                 style="height: 250px; object-fit: contain;">
                        </a>

                        <div class="card-body d-flex flex-column">
                            <h6 class="card-title fw-bold text-truncate">
                                <a href="@Url.Action("Detail", "Product", new { id = item.MaSP })" class="text-decoration-none text-dark">
                                    @item.TenSP
                                </a>
                            </h6>
                            <div class="mb-2 text-warning small">
                                <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                            </div>

                            <div class="mt-auto d-flex justify-content-between align-items-center">
                                <span class="fw-bold text-success fs-5">@string.Format("{0:N0} ₫", item.Gia)</span>

                                <a href="javascript:void(0)"
                                   class="btn btn-success rounded-circle btn-add-ajax d-flex align-items-center justify-content-center"
                                   data-id="@item.MaSP"
                                   style="width: 38px; height: 38px;">
                                    <i class="fas fa-plus text-white"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section class="py-5" style="background-color: var(--cocoon-brown);">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <img src="@Url.Content("~/Images/poster2.jpg")" class="img-fluid rounded-3 shadow">
            </div>
            <div class="col-lg-6 text-white ps-lg-5 pt-4 pt-lg-0">
                <h2 class="fw-bold mb-3">Câu chuyện Cocoon</h2>
                <p>Cocoon là thương hiệu mỹ phẩm thuần chay (100% vegan) sinh ra để dành cho người Việt.</p>
                <div class="row mt-4">
                    <div class="col-6">
                        <h5 class="fw-bold"><i class="fas fa-leaf text-success me-2"></i> Nguyên liệu Việt</h5>
                        <p class="small opacity-75">Từ Đắk Lắk, Tiền Giang, Hòa Bình...</p>
                    </div>
                    <div class="col-6">
                        <h5 class="fw-bold"><i class="fas fa-heart text-danger me-2"></i> Cruelty-free</h5>
                        <p class="small opacity-75">Không thử nghiệm trên động vật</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.btn-add-ajax').click(function (e) {
                e.preventDefault();
                var btn = $(this);
                var productId = btn.data('id');

                $.ajax({
                    url: '/Cart/AddToCartAjax',
                    type: 'POST',
                    data: { maSP: productId },
                    success: function (response) {

                        if (response.requireLogin) {
                            if (confirm("Bạn cần đăng nhập để mua hàng. Đi đến trang đăng nhập ngay?")) {
                                var currentUrl = window.location.pathname;
                                var returnUrl = currentUrl + "?addProId=" + productId;
                                window.location.href = "/Account/Login?returnUrl=" + encodeURIComponent(returnUrl);
                            }
                            return;
                        }

                        if (response.success) {
                            $('#cart-badge-count').text(response.count);

                            var productImg = btn.closest('.card-product').find('.img-product-fly');
                            var cartIcon = $('#cart-icon-container');

                            if (productImg.length && cartIcon.length) {
                                var imgSrc = productImg.attr('src');
                                var flyImg = $('<div>').css({
                                    'background-image': 'url("' + imgSrc + '")',
                                    'background-size': 'cover',
                                    'background-position': 'center',
                                    'width': '80px', 'height': '80px',
                                    'border-radius': '50%',
                                    'border': '2px solid #2d9446',
                                    'position': 'absolute', 'z-index': '9999',
                                    'top': productImg.offset().top + (productImg.height() / 2) - 40,
                                    'left': productImg.offset().left + (productImg.width() / 2) - 40
                                });

                                $('body').append(flyImg);

                                flyImg.animate({
                                    'top': cartIcon.offset().top + 10,
                                    'left': cartIcon.offset().left + 10,
                                    'width': '20px', 'height': '20px', 'opacity': 0.5
                                }, 800, function () {
                                    $(this).remove();
                                    cartIcon.animate({ top: "-=5px" }, 100).animate({ top: "+=5px" }, 100);
                                });
                            }
                        }
                    },
                    error: function () { alert("Lỗi kết nối server."); }
                });
            });
        });
    </script>
}