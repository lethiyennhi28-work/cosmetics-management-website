@{
    ViewBag.Title = "Liên hệ";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold" style="color: var(--cocoon-brown);">LIÊN HỆ VỚI CHÚNG TÔI</h2>
        <p class="text-muted">Chúng tôi luôn sẵn sàng lắng nghe ý kiến của bạn</p>
    </div>

    <div class="row">
        <div class="col-md-5 mb-4">
            <div class="p-4 bg-light rounded h-100">
                <h4 class="fw-bold mb-4" style="color: var(--cocoon-brown);">Thông tin liên hệ</h4>

                <div class="d-flex mb-3">
                    <div class="me-3"><i class="fas fa-map-marker-alt fa-lg text-success"></i></div>
                    <div>
                        <h6 class="fw-bold">Địa chỉ văn phòng</h6>
                        <p class="text-muted small">140/1 Lý Chính Thắng, Phường 7, Quận 3, TP. Hồ Chí Minh</p>
                    </div>
                </div>

                <div class="d-flex mb-3">
                    <div class="me-3"><i class="fas fa-phone-alt fa-lg text-success"></i></div>
                    <div>
                        <h6 class="fw-bold">Hotline</h6>
                        <p class="text-muted small">1900 9300 (8:00 - 17:00)</p>
                    </div>
                </div>

                <div class="d-flex mb-3">
                    <div class="me-3"><i class="fas fa-envelope fa-lg text-success"></i></div>
                    <div>
                        <h6 class="fw-bold">Email hỗ trợ</h6>
                        <p class="text-muted small">cskh@cocoonvietnam.com</p>
                    </div>
                </div>

                <hr>
                <h6 class="fw-bold mb-3">Theo dõi chúng tôi</h6>
                <div>
                    <a href="#" class="me-3 text-secondary"><i class="fab fa-facebook fa-2x"></i></a>
                    <a href="#" class="me-3 text-secondary"><i class="fab fa-instagram fa-2x"></i></a>
                    <a href="#" class="text-secondary"><i class="fab fa-youtube fa-2x"></i></a>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="card border-0 shadow-sm p-4">
                <h4 class="fw-bold mb-4">Gửi thắc mắc cho chúng tôi</h4>
                <form>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Họ tên *</label>
                            <input type="text" class="form-control" placeholder="Nhập họ tên của bạn">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Số điện thoại *</label>
                            <input type="text" class="form-control" placeholder="Nhập số điện thoại">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" placeholder="Nhập email của bạn">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nội dung cần hỗ trợ *</label>
                        <textarea class="form-control" rows="5" placeholder="Bạn cần hỗ trợ gì?"></textarea>
                    </div>
                    <button type="button" class="btn btn-cocoon px-4" onclick="alert('Cảm ơn bạn đã liên hệ! Chúng tôi sẽ phản hồi sớm nhất.')">
                        GỬI TIN NHẮN
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="mt-5">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.0573416091893!2d106.62625947592531!3d10.806920289343708!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31752be27ea41e05%3A0xfa77697a39f13ab0!2zMTQwIEzDqiBUcuG7jW5nIFThuqVuLCBUw6J5IFRo4bqhbmgsIFTDom4gUGjDuiwgVGjDoG5oIHBo4buRIEjhu5MgQ2jDrSBNaW5oIDcwMDAwMCwgVmnhu4d0IE5hbQ!5e0!3m2!1svi!2s!4v1765192697921!5m2!1svi!2s" width="500" height="250" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
</div>