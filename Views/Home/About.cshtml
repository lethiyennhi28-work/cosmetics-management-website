@{
    ViewBag.Title = "Về Cocoon";
}

<section class="py-5" style="background-color: var(--cocoon-brown); color: white;">
    <div class="container text-center">
        <h1 class="fw-bold display-5">CÂU CHUYỆN COCOON</h1>
        <p class="lead">Mỹ phẩm thuần chay - Cho nét đẹp thuần Việt</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row align-items-center mb-5">
            <div class="col-md-6">
                <img src="~/Images/poster1.jpg" class="img-fluid rounded shadow" alt="Story Cocoon">
            </div>
            <div class="col-md-6 ps-md-5 mt-4 mt-md-0">
                <h3 class="fw-bold" style="color: var(--cocoon-brown);">Sứ mệnh của chúng tôi</h3>
                <p class="text-muted">
                    Cocoon là thương hiệu mỹ phẩm <strong>100% thuần chay (Vegan)</strong> đầu tiên của Việt Nam.
                    Chúng tôi ra đời với sứ mệnh mang lại vẻ đẹp tự nhiên, an toàn và bền vững cho người Việt.
                </p>
                <p class="text-muted">
                    Tại Cocoon, chúng tôi tin rằng vẻ đẹp thật sự không cần phải đánh đổi bằng sự đau đớn của các loài động vật
                    hay sự hủy hoại môi trường.
                </p>
                <ul class="list-unstyled mt-3">
                    <li class="mb-2"><i class="fas fa-leaf text-success me-2"></i> 100% Nguyên liệu thực vật</li>
                    <li class="mb-2"><i class="fas fa-paw text-success me-2"></i> Không thử nghiệm trên động vật</li>
                    <li class="mb-2"><i class="fas fa-globe-asia text-success me-2"></i> Tự hào sản xuất tại Việt Nam</li>
                </ul>
            </div>
        </div>

        <hr class="my-5 text-muted">

        <div class="text-center mb-5">
            <h3 class="fw-bold mb-4" style="color: var(--cocoon-brown);">Nguyên liệu đặc trưng</h3>
            <div class="row g-4">
                <div class="col-md-3 col-6">
                    <div class="p-4 border rounded bg-white h-100 shadow-sm">
                        <i class="fas fa-coffee fa-3x text-warning mb-3"></i>
                        <h5 class="fw-bold">Cà phê Đắk Lắk</h5>
                        <p class="small text-muted">Giàu caffeine, giúp da săn chắc và đều màu.</p>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="p-4 border rounded bg-white h-100 shadow-sm">
                        <i class="fas fa-carrot fa-3x text-warning mb-3"></i> <h5 class="fw-bold">Bí đao</h5>
                        <p class="small text-muted">Thanh mát, giảm dầu và mụn ẩn hiệu quả.</p>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="p-4 border rounded bg-white h-100 shadow-sm">
                        <i class="fas fa-fan fa-3x text-danger mb-3"></i>
                        <h5 class="fw-bold">Hoa hồng Cao Bằng</h5>
                        <p class="small text-muted">Dưỡng ẩm sâu, se khít lỗ chân lông.</p>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="p-4 border rounded bg-white h-100 shadow-sm">
                        <i class="fas fa-tint fa-3x text-info mb-3"></i>
                        <h5 class="fw-bold">Dầu dừa Bến Tre</h5>
                        <p class="small text-muted">Mềm môi, dưỡng tóc bóng mượt tự nhiên.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>