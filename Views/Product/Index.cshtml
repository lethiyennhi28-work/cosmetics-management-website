@model IEnumerable<Nhom5_Mypham.Models.SANPHAM>

@{
    ViewBag.Title = "Danh sách sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="bg-light py-4 mb-4">
    <div class="container text-center">
        <h1 class="fw-bold" style="color: #6c4b2b;">TẤT CẢ SẢN PHẨM</h1>
        <p class="text-muted">Khám phá vẻ đẹp thuần chay từ thiên nhiên</p>
    </div>
</div>

<div class="container pb-5">
    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning text-center">Hiện chưa có sản phẩm nào.</div>
    }
    else
    {
        <div class="product-area">
            <div class="row align-items-start h-100">
                <div class="col-md-3 mb-4 filter-col">
                    <div class="card shadow-sm border-0 p-3">
                        <h5 class="fw-bold text-success"><i class="fas fa-filter me-2"></i>BỘ LỌC</h5>
                        <hr />
                        @using (Html.BeginForm("Index", "Product", FormMethod.Get))
                        {
                            <div class="mb-3">
                                <label class="small fw-bold">Loại da:</label>
                                <select name="loaiDa" class="form-select form-select-sm shadow-none">
                                    <option value="">-- Tất cả --</option>
                                    <option value="Da dầu" @(Request.QueryString["loaiDa"] == "Da dầu" ? "selected" : "")>Da dầu</option>
                                    <option value="Da khô" @(Request.QueryString["loaiDa"] == "Da khô" ? "selected" : "")>Da khô</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="small fw-bold">Giá từ (₫):</label>
                                <input type="number" name="giaTu" value="@Request.QueryString["giaTu"]" class="form-control form-control-sm shadow-none" />
                            </div>
                            <button type="submit" class="btn btn-success btn-sm w-100 fw-bold rounded-pill">ÁP DỤNG</button>
                            <a href="@Url.Action("Index", "Product")" class="btn btn-link btn-sm w-100 text-decoration-none text-muted mt-2 small">Xóa bộ lọc</a>
                        }
                    </div>
                </div>

                <div class="col-md-9">
                    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                        @foreach (var item in Model)
                        {
                            <div class="col">
                                <div class="card h-100 shadow-sm border-0 product-card">
                                    <a href="@Url.Action("Detail", "Product", new { id = item.MaSP.Trim() })" class="text-decoration-none">
                                        <div class="position-relative overflow-hidden">
                                            <img src="~/Images/@item.HinhAnh"
                                                 class="card-img-top p-3"
                                                 alt="@item.TenSP"
                                                 style="height: 250px; object-fit: contain; transition: transform 0.3s ease;">

                                            @if (item.SoLuong == 0)
                                            {
                                                <span class="position-absolute top-0 start-0 bg-danger text-white px-2 py-1 m-2 rounded small">Hết hàng</span>
                                            }
                                        </div>
                                    </a>

                                    <div class="card-body d-flex flex-column text-center">
                                        <h5 class="card-title fs-6 mb-2" style="height: 40px; overflow: hidden;">
                                            <a href="@Url.Action("Detail", "Product", new { id = item.MaSP.Trim() })" class="text-decoration-none text-dark fw-bold">
                                                @item.TenSP
                                            </a>
                                        </h5>

                                        <p class="card-text text-danger fw-bold fs-5 mb-3">
                                            @String.Format("{0:0,0}", item.Gia) đ
                                        </p>

                                        <div class="mt-auto">
                                            <div class="d-grid gap-2">
                                                <a href="@Url.Action("Detail", "Product", new { id = item.MaSP.Trim() })" class="btn btn-outline-secondary btn-sm rounded-pill">
                                                    Xem chi tiết
                                                </a>

                                                @if (item.SoLuong > 0)
                                                {
                                                    <form action="@Url.Action("ThemGioHang", "GioHang")" method="post">
                                                        <input type="hidden" name="MaSP" value="@item.MaSP.Trim()" />
                                                        <input type="hidden" name="SoLuong" value="1" />
                                                        <button type="submit" class="btn btn-success btn-sm w-100 rounded-pill">
                                                            <i class="fas fa-cart-plus me-1"></i> Thêm vào giỏ
                                                        </button>
                                                    </form>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

