@model List<Nhom5_Mypham.Models.CartItem>
@{
    ViewBag.Title = "Giỏ hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger text-center fw-bold shadow-sm my-3">
        <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"]
    </div>
}
<style>
    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    input[type=number] {
        -moz-appearance: textfield;
    }
</style>

<div class="container py-5">
    <h2 class="text-center fw-bold mb-4" style="color: #8d5330;">GIỎ HÀNG CỦA BẠN</h2>

    @if (Model == null || Model.Count == 0)
    {
        <div class="text-center py-5">
            <p class="lead text-muted">Giỏ hàng trống trơn.</p>
            <a href="@Url.Action("Index", "Home")" class="btn btn-success rounded-pill px-4">Mua sắm ngay</a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-lg-8 mb-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-0">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Sản phẩm</th>
                                    <th>Giá</th>
                                    <th>Số lượng</th>
                                    <th>Thành tiền</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr id="row-@item.MaSP">
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <img src="@Url.Content("~/Images/" + item.HinhAnh)"
                                                     class="rounded border me-3"
                                                     style="width: 60px; height: 60px; object-fit: cover;">
                                                <div>
                                                    <h6 class="mb-0 fw-bold">@item.TenSP</h6>
                                                    <small class="text-muted">Mã: @item.MaSP</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>@string.Format("{0:N0}", item.Gia)</td>

                                        <td>
                                            <div class="input-group input-group-sm" style="width: 110px;">
                                                <button class="btn btn-outline-secondary btn-update" data-id="@item.MaSP" data-type="minus" type="button">-</button>

                                                <input type="number" class="form-control text-center input-qty"
                                                       value="@item.SoLuong" min="1"
                                                       data-id="@item.MaSP"
                                                       id="qty-@item.MaSP">

                                                <button class="btn btn-outline-secondary btn-update" data-id="@item.MaSP" data-type="plus" type="button">+</button>
                                            </div>
                                        </td>

                                        <td class="fw-bold text-success" id="total-@item.MaSP">
                                            @string.Format("{0:N0}", item.ThanhTien)
                                        </td>
                                        <td>
                                            <a href="@Url.Action("RemoveFromCart", "Cart", new { maSP = item.MaSP })" class="text-danger">
                                                <i class="fas fa-trash-alt"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm bg-light">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3" style="color: #8d5330;">Thông tin giao hàng</h5>

                        <form action="@Url.Action("Checkout", "Cart")" method="post">

                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted">Họ tên *</label>
                                <input type="text" name="hoTen" class="form-control" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted">Số điện thoại *</label>
                                <input type="text" name="sdt" class="form-control" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted">Địa chỉ *</label>
                                <input type="text" name="diaChi" class="form-control" required>
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-bold text-muted">Thanh toán</label>
                                @if (ViewBag.MaPT != null)
                                {
                                    @Html.DropDownList("maPT", (SelectList)ViewBag.MaPT, new { @class = "form-select" })
                                }
                                else
                                {
                                    <select class="form-select" disabled>
                                        <option>Đang tải phương thức...</option>
                                    </select>
                                }
                            </div>

                            <hr class="my-3">

                            <div class="d-flex justify-content-between mb-4">
                                <span class="fw-bold fs-5">Tổng cộng:</span>
                                <span class="fw-bold fs-5 text-danger" id="cart-total">
                                    @string.Format("{0:N0} ₫", Model.Sum(x => x.ThanhTien))
                                </span>
                            </div>

                            <button type="submit" class="btn btn-success w-100 py-2 fw-bold rounded-pill">
                                ĐẶT HÀNG NGAY
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            $('.btn-update').click(function (e) {
                e.preventDefault(); 
                var btn = $(this);
                var id = btn.data('id');
                var type = btn.data('type'); 
                var input = $('#qty-' + id);
                var currentVal = parseInt(input.val());

                var newVal = type === 'plus' ? currentVal + 1 : currentVal - 1;
                if (newVal < 1) newVal = 1;

                input.val(newVal);
                updateCartAjax(id, newVal);
            });

            $('.input-qty').change(function () {
                var input = $(this);
                var id = input.data('id');
                var val = parseInt(input.val());

                if (isNaN(val) || val < 1) {
                    val = 1;
                    input.val(1);
                }
                updateCartAjax(id, val);
            });

            function updateCartAjax(id, qty) {
                $.ajax({
                    url: '/Cart/UpdateCart', 
                    type: 'POST',
                    data: { maSP: id, quantity: qty },
                    success: function (res) {
                        if (res.success) {
                            var formatConfig = { style: 'currency', currency: 'VND' };

                            $('#total-' + id).text(res.newTotal.toLocaleString('vi-VN', formatConfig).replace('₫', '') + ' ₫');

                            $('#cart-total').text(res.cartTotal.toLocaleString('vi-VN', formatConfig).replace('₫', '') + ' ₫');
                        }
                    },
                    error: function () {
                        alert('Lỗi cập nhật giỏ hàng!');
                    }
                });
            }
        });
    </script>
}